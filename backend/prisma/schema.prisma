datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  password      String
  createdAt     DateTime      @default(now())

  subjects      Subject[]
  tasks         Task[]
  documents     Document[]
  opportunities Opportunity[]
}

model Subject {
  id        String   @id @default(uuid())
  name      String
  professor String?
  semester  String?
  userId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  tasks     Task[]
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime?
  status      String   @default("PENDENTE")
  priority    String   @default("MEDIA")

  userId      String
  subjectId   String?

  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  subject     Subject? @relation(fields: [subjectId], references: [id])
}

model Document {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("PENDENTE")
  userId      String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

model Opportunity {
  id          String   @id @default(uuid())
  title       String
  description String?
  link        String?
  deadline    DateTime?
  status      String   @default("ABERTO")
  userId      String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}